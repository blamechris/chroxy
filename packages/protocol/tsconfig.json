{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rewriteRelativeImportExtensions": true,
    // "node" is required for the node-only ./project subpath (P2-2); the
    // browser-consumed barrel must not start using node globals.
    "types": ["node"]
  },
  "include": ["src"]
}

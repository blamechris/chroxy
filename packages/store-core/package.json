{
  "name": "@chroxy/store-core",
  "version": "0.10.0",
  "description": "Shared store logic for Chroxy app and dashboard",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./crypto": {
      "import": "./dist/crypto.js",
      "types": "./dist/crypto.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/postbuild-crypto.mjs && node scripts/postbuild-esm-specifiers.mjs",
    "typecheck": "tsc --noEmit",
    "build:crypto": "tsc src/crypto.ts --outDir dist --module ESNext --target ES2022 --declaration --moduleResolution node --esModuleInterop --skipLibCheck && node scripts/postbuild-crypto.mjs",
    "prepare": "npm run build",
    "pretest": "npm run build:crypto",
    "test": "vitest run"
  },
  "dependencies": {
    "@chroxy/protocol": "0.10.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "vitest": "^3.2.1"
  }
}

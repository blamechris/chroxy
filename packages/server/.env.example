# =============================================================================
# Chroxy Server — Environment Variables
# =============================================================================
# All variables are optional. Config precedence: CLI flags > ENV > config file > defaults.
# Run 'npx chroxy init' to generate ~/.chroxy/config.json interactively.

# --- Core ---
PORT=8765                          # WebSocket server port
API_TOKEN=                         # Auth token (generate with: npx chroxy init)

# --- Session ---
# CHROXY_CWD=/path/to/project     # Default working directory for new sessions
# CHROXY_MODEL=sonnet              # Default Claude model (sonnet, opus, haiku)
# CHROXY_PROVIDER=claude-sdk       # Provider: claude-sdk (default) or claude-cli

# --- Security ---
# CHROXY_NO_AUTH=false             # Disable auth (binds to localhost only)
# CHROXY_NO_ENCRYPT=false          # Disable E2E encryption (cannot use with tunnels)
# CHROXY_TOKEN_EXPIRY=24h          # Auto-rotate tokens (e.g. 1h, 12h, 7d)

# --- Tunnel ---
# CHROXY_TUNNEL=quick              # Tunnel mode: quick (default), named, none
# CHROXY_TUNNEL_NAME=              # Named tunnel identifier (requires Cloudflare account)
# CHROXY_TUNNEL_HOSTNAME=          # Custom hostname for named tunnel
# CHROXY_EXTERNAL_URL=             # External reverse proxy URL (skips tunnel)

# --- Limits ---
# CHROXY_MAX_PAYLOAD=1048576       # Max WebSocket payload bytes (default: 1MB)
# CHROXY_MAX_TOOL_INPUT=           # Max tool input size in permission broadcasts
# CHROXY_COST_BUDGET=              # Per-session cost budget in USD (e.g. 5.00)
# CHROXY_SESSION_TIMEOUT=          # Session idle timeout (e.g. 30m, 2h)
# CHROXY_MAX_RESTARTS=10           # Max respawns before giving up

# --- Advanced ---
# CHROXY_ALLOWED_TOOLS=            # Comma-separated list of allowed tools
# CHROXY_LEGACY_CLI=false          # Use legacy claude -p mode instead of SDK
# CHROXY_TRANSFORMS=               # JSON array of message transforms
# CHROXY_TUNNEL_CONFIG=            # JSON object with tunnel-specific config

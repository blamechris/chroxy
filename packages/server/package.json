    "bonjour-service": "^1.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.3.0",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^9.0.0",
    "ws": "^8.16.0",
    "zod": "^4.3.6"
  },
  "engines": {

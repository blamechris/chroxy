{
  "name": "@chroxy/server",
  "version": "0.6.0",
  "description": "Chroxy server daemon and CLI",
  "type": "module",
  "main": "src/cli.js",
  "bin": {
    "chroxy": "src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js start",
    "dev": "node --watch src/cli.js start",
    "test": "node --test --test-force-exit './tests/**/*.test.js'",
    "test:integration": "node --test ./tests/*.integration.test.js",
    "lint": "eslint src/",
    "dashboard:dev": "vite --config src/dashboard-next/vite.config.ts src/dashboard-next",
    "dashboard:build": "vite build --config src/dashboard-next/vite.config.ts src/dashboard-next",
    "dashboard:typecheck": "tsc --noEmit -p src/dashboard-next/tsconfig.json",
    "dashboard:test": "vitest run --config src/dashboard-next/vite.config.ts",
    "dashboard:generate-tokens": "node scripts/generate-theme-tokens.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@chroxy/protocol": "*",
    "@chroxy/store-core": "*",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "bonjour-service": "^1.3.0",
    "commander": "^12.0.0",
    "dompurify": "^3.3.1",
    "dotenv": "^16.3.0",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.16.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blamechris/chroxy.git",
    "directory": "packages/server"
  },
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.3",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}

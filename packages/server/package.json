{
  "name": "@chroxy/server",
  "version": "0.2.0",
  "description": "Chroxy server daemon and CLI",
  "type": "module",
  "main": "src/cli.js",
  "bin": {
    "chroxy": "src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js start",

{
  "identifier": "default",
  "description": "Default capabilities for Chroxy desktop. Allows the embedded dashboard, served from http://127.0.0.1:<server-port>, to invoke the custom commands declared in build.rs.",
  "windows": ["main", "dashboard", "qr_popup"],
  "remote": {
    "urls": [
      "http://127.0.0.1:*",
      "http://localhost:*"
    ]
  },
  "permissions": [
    "core:default",
    "shell:allow-open",
    "autostart:default",
    "notification:default",
    "updater:default",
    "process:allow-restart",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "dialog:allow-open",
    "allow-get-server-info",
    "allow-get-server-logs",
    "allow-get-startup-logs",
    "allow-start-server",
    "allow-stop-server",
    "allow-restart-server",
    "allow-discover-lan-servers",
    "allow-get-qr-code-svg",
    "allow-pick-directory",
    "allow-check-dependencies",
    "allow-get-setup-state",
    "allow-save-setup-config",
    "allow-get-tunnel-mode",
    "allow-set-tunnel-mode",
    "allow-get-expose-on-lan",
    "allow-set-expose-on-lan",
    "allow-get-summon-hotkey",
    "allow-set-summon-hotkey",
    "allow-get-allow-auto-permission-mode",
    "allow-set-allow-auto-permission-mode",
    "allow-update-tray-badge",
    "allow-private-no-it-all-status",
    "allow-launch-private-no-it-all",
    "allow-voice-available",
    "allow-start-voice-input",
    "allow-stop-voice-input",
    "allow-reset-speech-permissions",
    "allow-tile-window",
    "allow-read-clipboard-image",
    "allow-reveal-in-finder"
  ]
}

{
  "identifier": "default",
  "description": "Default capabilities for Chroxy desktop",
  "windows": ["main", "dashboard", "qr_popup"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "autostart:default",
    "notification:default",
    "updater:default",
    "process:allow-restart",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "dialog:allow-open"
  ]
}

{
  "productName": "Chroxy",
  "version": "0.3.3",
  "identifier": "com.chroxy.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../server && npm run dashboard:dev",
    "beforeBuildCommand": "cd ../server && TAURI_ENV_PLATFORM= npm run dashboard:build && cd ../desktop && bash scripts/bundle-server.sh"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' http://localhost:* http://127.0.0.1:*; connect-src ws://localhost:* ws://127.0.0.1:* http://localhost:* http://127.0.0.1:*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Chroxy",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "visible": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": {
      "server-bundle": "server"
    },
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "$APPLE_SIGNING_IDENTITY"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/blamechris/chroxy/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzMkI3MUIzQTk5RjhEODEKUldTQmpaK3BzM0Vybzd6T20zL3NjbkZxb3Q4VkdFZklkaS8zM0ltMzF0Yllmd2k2NnVhR2UzeXIK"
    }
  }
}

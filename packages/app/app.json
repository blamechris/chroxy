{
  "expo": {
    "name": "Chroxy",
    "slug": "chroxy",
    "version": "0.6.10",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.blamechris.chroxy",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Chroxy scans your local network to discover running Chroxy servers",
        "NSSpeechRecognitionUsageDescription": "Allow Chroxy to use speech recognition for voice input.",
        "NSMicrophoneUsageDescription": "Allow Chroxy to use the microphone for voice input.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f1a"
      },
      "package": "com.blamechris.chroxy",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "chroxy",
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Chroxy to scan QR codes"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Chroxy to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow Chroxy to use speech recognition for voice input."
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "expo-live-activity"
    ],
    "extra": {
      "eas": {
        "projectId": "5747b2cd-e15a-4742-9562-de949408f896"
      }
    }
  }
}

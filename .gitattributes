* text=auto eol=lf

# Shell scripts MUST stay LF even on a Windows checkout with core.autocrlf=true —
# CRLF breaks direct execution under WSL/Linux (`./script.sh` -> `bash\r: not
# found`). Explicit over the `* eol=lf` rule above so it can never fall back to
# content auto-detection (#6652).
*.sh text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.icns binary

# The signed Mach-O speech helper (#3830) is EXTENSIONLESS, so no extension glob
# (like the *.icns rule above) can ever match it — hence an explicit path rule.
# Marking it `binary` removes any reliance on git's content-based (NUL-byte)
# auto-detection so it can never be LF-normalized. (#6489)
packages/desktop/src-tauri/swift/speech-helper binary

docs/empirical/*.jsonl linguist-generated
